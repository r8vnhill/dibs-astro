{
    "name": "dibs-astro",
    "type": "module",
    "version": "0.19.0",
    "scripts": {
        "check:architecture": "node scripts/check-layer-boundaries.mjs",
        "build:content-core": "pnpm --dir packages/content-core run build",
        "build:site-core": "pnpm --dir packages/site-core run build",
        "check:content-core": "pnpm --dir packages/content-core run check && pnpm run test:typecheck:content-core",
        "check:site-core": "pnpm --dir packages/site-core run check",
        "generate-icons": "node generate-icons-index.js",
        "generate:bibliography-catalog": "node scripts/build-bibliography-catalog.mjs",
        "generate:lesson-metadata": "node scripts/generate-lesson-metadata.mjs",
        "predev": "pnpm run build:content-core && pnpm run build:site-core && pnpm run generate:bibliography-catalog && pnpm run generate:lesson-metadata",
        "dev": "node scripts/dev.mjs",
        "prebuild": "pnpm run build:content-core && pnpm run build:site-core && pnpm run generate:bibliography-catalog && pnpm run generate:lesson-metadata",
        "build": "node ./node_modules/astro/astro.js build",
        "preview": "node scripts/preview-dev.mjs",
        "astro": "astro",
        "fmt": "dprint fmt",
        "check": "pnpm run check:content-core && pnpm run check:site-core && pnpm run generate:bibliography-catalog && node scripts/run-astro-check.mjs && node scripts/generate-lesson-metadata.mjs --dry-run --quiet && pnpm run check:architecture",
        "bibliography:report": "pnpm run generate:bibliography-catalog && node scripts/bibliography-report.mjs",
        "predeploy": "pnpm run build:content-core && pnpm run build:site-core && pnpm run generate:bibliography-catalog && pnpm run generate:lesson-metadata",
        "deploy": "astro build && wrangler deploy",
        "test": "pnpm test:unit && pnpm test:astro",
        "test:unit": "vitest run",
        "test:typecheck:content-core": "node ./node_modules/vitest/vitest.mjs list --typecheck.only --config vitest.content-core.types.config.ts && pnpm --dir packages/content-core exec tsc --noEmit --pretty false",
        "test:astro": "node ./node_modules/vitest/vitest.mjs run --config vitest.astro.config.ts",
        "test:watch": "vitest --watch",
        "test:watch:astro": "node ./node_modules/vitest/vitest.mjs --watch --config vitest.astro.config.ts",
        "test:ui": "vitest --ui"
    },
    "dependencies": {
        "@astrojs/check": "^0.9.5",
        "@astrojs/markdoc": "^0.15.8",
        "@lucide/astro": "^0.536.0",
        "@ravenhill/content-core": "workspace:*",
        "@ravenhill/site-core": "workspace:*",
        "@tabler/icons": "^3.34.1",
        "@tailwindcss/forms": "^0.5.10",
        "@types/hast": "^3.0.4",
        "@types/react": "^19.1.9",
        "@types/react-dom": "^19.1.7",
        "astro": "5.15.1",
        "astro-expressive-code": "^0.41.3",
        "clsx": "^2.1.1",
        "jsonld": "^9.0.0",
        "lucide-react": "^0.536.0",
        "n3": "^2.0.3",
        "phosphor-react": "^1.4.1",
        "rehype": "^13.0.2",
        "tailwind-variants": "^2.1.0",
        "tw-animate-css": "^1.3.6",
        "unified": "^11.0.5",
        "unist-util-visit": "^5.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@astrojs/react": "^4.4.0",
        "@shikijs/colorized-brackets": "^3.9.1",
        "@shikijs/transformers": "^3.9.1",
        "@tailwindcss/vite": "^4.1.11",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.1.0",
        "@testing-library/user-event": "^14.5.2",
        "@types/jest": "^30.0.0",
        "cheerio": "^1.2.0",
        "dprint": "^0.48.0",
        "es-module-lexer": "^2.0.0",
        "fast-check": "^4.5.3",
        "fast-glob": "^3.3.3",
        "get-tsconfig": "^4.14.0",
        "globby": "^16.2.0",
        "jsdom": "^25.0.0",
        "lint-staged": "^15.2.10",
        "picomatch": "^4.0.4",
        "prettier": "^3.6.2",
        "prettier-plugin-astro": "^0.14.1",
        "prettier-plugin-classnames": "^0.8.2",
        "prettier-plugin-merge": "^0.8.0",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "publint": "^0.3.19",
        "react": "^19.1.1",
        "react-dom": "^19.1.1",
        "shiki": "^3.9.1",
        "shiki-transformer-color-highlight": "^1.1.0",
        "shiki-transformer-copy-button": "^0.0.5",
        "tailwindcss": "^4.1.11",
        "tsup": "^8.5.1",
        "typescript": "^5.9.2",
        "vitest": "^3.2.4",
        "wrangler": "^4.27.0"
    },
    "lint-staged": {
        "*": [
            "pnpm dprint fmt --"
        ]
    }
}
