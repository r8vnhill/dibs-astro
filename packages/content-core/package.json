{
    "name": "@ravenhill/content-core",
    "version": "0.1.0",
    "type": "module",
    "private": false,
    "description": "Content abstraction layer for reusable documentation and learning systems.",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsup",
        "check": "pnpm run build && tsc --noEmit && publint --strict && pnpm run pack:check && pnpm run consumer:check",
        "consumer:check": "node scripts/validate-packed-consumer.mjs",
        "pack:check": "pnpm pack --dry-run --json | node scripts/assert-pack-files.mjs",
        "pack:dry-run": "pnpm pack --dry-run --json"
    },
    "publishConfig": {
        "@ravenhill:registry": "https://gitlab.com/api/v4/projects/71752456/packages/npm/",
        "access": "restricted"
    }
}
