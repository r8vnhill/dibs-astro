---
/**
 * TabsContent.astro – Starwind Tabs panel content.
 * ------------------------------------------------
 * Represents the content area corresponding to a tab trigger.
 * Controlled dynamically via JS by matching `data-value`.
 * Hidden when inactive using `data-state="inactive"` and `hidden`.
 *
 * ## Export Mode
 *
 * In PDF export mode (`renderMode="pdf"`), the content is rendered visibly without
 * the `hidden` attribute. An optional `label` prop can be used to render a static heading
 * before the content; if no label is provided, the tab `value` is used as a fallback.
 */

import { resolveLessonExportContext, type ResolveLessonExportContextInput } from "~/lib/presentation/export-mode";
import type { LessonRenderMode } from "~/lib/presentation/export-mode";
import type { HTMLAttributes } from "astro/types";
import { tv } from "tailwind-variants";

/**
 * Props accepted by the TabsContent component.
 * Inherits most <div> attributes, except a few internal ones.
 */
interface Props extends Omit<HTMLAttributes<"div">, "id" | "role" | "tabindex" | "hidden"> {
    /**
     * The tab value this content is associated with.
     */
    value: string;

    /**
     * Optional label for export mode heading.
     *
     * If provided, a heading will be rendered before the content in PDF mode.
     * Falls back to `value` if not provided.
     */
    label?: string;

    /**
     * Optional render mode for export/PDF output.
     * Defaults to `"web"` if not provided.
     */
    renderMode?: LessonRenderMode;
}

/**
 * Tailwind Variants config for content container.
 */
const tabsContent = tv({
    base: [
        "mt-2",
        "focus-visible:outline-2 focus-visible:outline-offset-2",
        "focus-visible:outline-outline",
    ],
});

const { value, class: className, label, renderMode, ...rest } = Astro.props;

// Resolve export context from props and request locals.
const exportContext = resolveLessonExportContext({
    renderMode,
    locals: Astro.locals,
} as ResolveLessonExportContextInput);
---

{
    exportContext.isPdfExport ? (
        <section data-export-role="tabs-panel" {...rest}>
            <h3 data-export-role="tabs-panel-heading" class="text-lg font-semibold mb-4">
                {label ?? value}
            </h3>
            <slot />
        </section>
    ) : (
        <div
            class={tabsContent({ class: className })}
            data-tabs-content
            data-value={value}
            data-state="inactive"
            role="tabpanel"
            tabindex="0"
            hidden
            {...rest}
        >
            <slot />
        </div>
    )
}
