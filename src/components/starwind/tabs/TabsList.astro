---
/**
 * TabsList.astro – Starwind Tabs trigger list.
 * --------------------------------------------
 * This component renders the tab trigger container (the clickable tabs).
 * It supports styling via Tailwind Variants and provides accessibility via `role="tablist"` and the
 * `data-tabs-list` attribute.
 *
 * ## Export Mode
 *
 * In PDF export mode, the TabsList is marked with `data-export-hidden="true"` to exclude it from
 * deterministic PDF output. Interactive tab controls are not meaningful in static export mode.
 */

import { resolveLessonExportContext, type ResolveLessonExportContextInput } from "~/lib/presentation/export-mode";
import type { LessonRenderMode } from "~/lib/presentation/export-mode";
import type { HTMLAttributes } from "astro/types";
import { tv } from "tailwind-variants";

/**
 * Props for the TabsList component.
 * `role` is omitted because it is hardcoded to "tablist".
 */
interface Props extends Omit<HTMLAttributes<"div">, "role"> {
    /**
     * Optional render mode for export/PDF output.
     * Defaults to `"web"` if not provided.
     */
    renderMode?: LessonRenderMode;
}

/**
 * Tailwind Variants definition for the tabs list.
 * Allows further extension if variants are added in the future.
 */
const tabsList = tv({
    base:
        "inline-flex w-full items-center justify-center rounded-md bg-muted p-1 text-muted-foreground gap-1",
    variants: {
        size: {
            sm: "text-sm gap-1",
            md: "text-base gap-1.5",
            lg: "text-lg gap-2",
        },
        orientation: {
            horizontal: "flex-row",
            vertical: "flex-col",
        },
    },
    defaultVariants: {
        size: "md",
        orientation: "horizontal",
    },
});

// Extract props
const {
    class: className,
    "aria-orientation": ariaOrientation = "horizontal",
    renderMode,
    ...rest
} = Astro.props;

// Resolve export context from props and request locals.
const exportContext = resolveLessonExportContext({
    renderMode,
    locals: Astro.locals,
} as ResolveLessonExportContextInput);
---

{
    !exportContext.isPdfExport && (
        <div
            class={tabsList({
                class: className,
                orientation: ariaOrientation ?? undefined,
            })}
            data-tabs-list
            role="tablist"
            aria-orientation={ariaOrientation}
            {...rest}
        >
            <slot />
        </div>
    )
}
