---
/**
 * @fileoverview Renders a semantic list item with an optional decorative icon.
 *
 * `ListItem` is a small layout primitive for content that should appear inside a parent `<ul>` or `<ol>`. It renders a 
 * root `<li>` with a horizontal flex layout, an optional left-aligned icon, and a content wrapper that can shrink
 * safely when the slotted content is long.
 *
 * The icon is decorative by default and is marked `aria-hidden="true"`. The slotted content remains the only 
 * meaningful content exposed by the component.
 *
 * Native `<li>` attributes are forwarded to the root element, while `class` is reintroduced as an explicit prop so 
 * callers can extend the root styling without changing the component contract.
 */
import type { HTMLAttributes } from "astro/types";
import type { AstroComponentFactory } from "~/types/astro-component";

/**
 * Props accepted by {@link ListItem}.
 *
 * This type composes native `<li>` attributes with a small set of custom props for icon rendering. The slot content is 
 * the primary payload of the list item; the icon is optional and decorative.
 *
 * ## Notes:
 *
 * - Native `<li>` attributes such as `id`, `role`, `aria-*`, `data-*`, and `style` are forwarded to the root element.
 * - `class` is omitted from {@link HTMLAttributes} and reintroduced here as a dedicated prop so the component can 
 *   merge caller-supplied classes with its own layout classes.
 */
type ListItemProps = Omit<HTMLAttributes<"li">, "class"> & {
    /**
     * Optional decorative icon rendered before the slotted content.
     *
     * The component currently invokes the icon with `width="1em"` and `height="1em"`, so the supplied
     * {@link AstroComponentFactory} should tolerate those props.
     */
    icon?: AstroComponentFactory;

    /**
     * Visual size applied to the icon wrapper through CSS `font-size`.
     *
     * Relative units such as `em` and `rem` are recommended so the icon scales predictably with nearby text.
     *
     * @defaultValue `"1.25em"`
     */
    iconSize?: string;

    /**
     * Text color applied to the icon wrapper.
     *
     * The default value is the literal CSS keyword `currentColor`, so the icon inherits the computed text color of the 
     * surrounding list item unless a different color is supplied explicitly.
     *
     * @defaultValue `"currentColor"`
     */
    iconColor?: string;

    /**
     * Additional classes merged into the root `<li>`.
     */
    class?: string;
};

const {
    icon: Icon = null,
    iconSize = "1.25em",
    iconColor = "currentColor",
    class: className = "",
    ...liProps
} = Astro.props as ListItemProps;

/**
 * Inline styles owned by the icon wrapper.
 *
 * `lineHeight: 1` keeps the icon box compact and avoids introducing extra vertical space through inherited line-height 
 * values.
 */
const iconStyle = {
    fontSize: iconSize,
    color: iconColor,
    lineHeight: 1,
} as const;
---

<!--
    Root contract:
    - the `<li>` owns the horizontal layout;
    - the icon, when present, is decorative and does not participate in semantics;
    - the content wrapper uses `min-w-0 flex-1` so long slotted content can wrap instead of forcing overflow in flex 
      layouts.
-->
<li class:list={["flex", "items-start", "gap-2", className]} {...liProps}>
    {
        Icon && (
            <span
                class:list={["shrink-0", "listitem__icon"]} style={iconStyle}
                aria-hidden="true"
            >
                <Icon width="1em" height="1em" />
            </span>
        )
    }

    <div class="min-w-0 flex-1">
        <slot />
    </div>
</li>
