---
/**
 * Assembles and renders bibliography references from a JSON-LD source.
 *
 * This component is the JSON-LD-facing orchestration layer for the references UI. It parses a
 * bibliography-like source, resolves the requested recommended and additional reference groups,
 * prepares any meaningful slot overrides, and then delegates per-reference rendering to
 * {@link ReferenceEntry}.
 *
 * The component is intentionally coordination-oriented. It does not decide how individual
 * reference kinds render. Rendering details for specific reference types belong in
 * {@link ReferenceEntry} and the leaf reference components it uses.
 *
 * ## Responsibilities
 *
 * - Parse and validate the raw bibliography source.
 * - Resolve the `recommended` and `additional` identifier groups.
 * - Extract raw fallback titles from the original source when normalized titles are unavailable.
 * - Resolve slot overrides only for the referenced identifiers.
 * - Pass prepared reference data to {@link References} and {@link ReferenceEntry}.
 *
 * ## Rendering model
 *
 * The component renders through {@link References}, filling its `recommended` and `additional`
 * slots only when those groups contain entries. Each resolved reference is rendered through a
 * single {@link ReferenceEntry} instance.
 *
 * ## Error handling
 *
 * Parsing and group resolution both honor the `strict` flag. When `strict` is `true`, malformed
 * data or inconsistent group references are expected to be treated as errors by the bibliography
 * helpers. When `strict` is `false`, those helpers may recover more permissively.
 */

import {
    extractFallbackTitles,
    parseBibliography,
    resolveReferenceGroups,
} from "~/lib/bibliography";
import type { BibliographyJsonLd } from "~/lib/bibliography";
import { prepareSlotsForReferences } from "./reference-content";
import ReferenceEntry from "./ReferenceEntry.astro";
import References from "./References.astro";

/**
 * Props accepted by {@link ReferencesFromJsonLd}.
 */
type Props = {
    /**
     * Raw bibliography source.
     *
     * This is typically a JSON-LD bibliography object, but a broader record-shaped value is also
     * accepted so the parsing layer can perform the final validation and normalization.
     */
    source:
        | BibliographyJsonLd
        | Record<string, unknown>;

    /**
     * Reference identifiers to render in the recommended section.
     *
     * The order of this array is preserved by the grouping helper unless the bibliography layer
     * explicitly normalizes it differently.
     */
    recommended: string[];

    /**
     * Reference identifiers to render in the additional section.
     *
     * Defaults to an empty array so the component can omit that section entirely when no
     * additional references are requested.
     */
    additional?: string[];

    /**
     * Optional heading for the outer {@link References} container.
     */
    heading?: string;

    /**
     * Optional heading for the recommended references section.
     */
    recommendedHeading?: string;

    /**
     * Optional heading for the additional references section.
     */
    additionalHeading?: string;

    /**
     * Controls whether bibliography parsing and group resolution should behave strictly.
     *
     * Defaults to `true`.
     */
    strict?: boolean;
};

const {
    source,
    recommended,
    additional = [],
    heading,
    recommendedHeading,
    additionalHeading,
    strict = true,
}: Props = Astro.props;

/**
 * Parse the raw source into the normalized bibliography representation used by the rendering
 * pipeline.
 *
 * The `sourceLabel` is included so downstream diagnostics can identify this component as the
 * parsing boundary.
 */
const parsed = parseBibliography(source, {
    strict,
    sourceLabel: "ReferencesFromJsonLd",
});

/**
 * Resolve the requested reference groups against the parsed bibliography.
 *
 * This step determines which references are available for the `recommended` and `additional` slots
 * rendered below.
 */
const grouped = resolveReferenceGroups(parsed, recommended, additional, {
    strict,
    sourceLabel: "ReferencesFromJsonLd",
});

/**
 * Extract fallback titles directly from the raw source.
 *
 * These titles are only used when the normalized reference model does not provide one, which helps
 * preserve useful user-facing labels even when the source is partially incomplete.
 */
const fallbackTitles = extractFallbackTitles(source);

/**
 * Collect the distinct identifiers referenced by either group.
 *
 * Slot preparation is restricted to this set so the component resolves only the overrides that can
 * actually be rendered.
 */
const referencedIds = Array.from(new Set([...recommended, ...additional]));

/**
 * Resolve per-reference slot overrides once for the whole render pass.
 *
 * The prepared slot data is shared by both groups so recommended and additional entries use the
 * same slot-resolution rules and do not repeat work.
 */
const preparedSlots = await prepareSlotsForReferences(Astro.slots, referencedIds);

/**
 * Build the props object for the outer {@link References} wrapper.
 *
 * Optional headings are added only when present so the wrapper receives a minimal prop set.
 */
const referencesProps = {
    ...(heading ? { heading } : {}),
    ...(recommendedHeading ? { recommendedHeading } : {}),
    ...(additionalHeading ? { additionalHeading } : {}),
};
---

<References {...referencesProps}>
    {
        grouped.recommended.length > 0 && (
            <Fragment slot="recommended">
                {
                    grouped.recommended.map((ref) => (
                        <ReferenceEntry
                            reference={ref} preparedSlots={preparedSlots[ref.id] || {}}
                            {...(fallbackTitles[ref.id]
                                ? { fallbackTitle: fallbackTitles[ref.id] }
                                : {})}
                        />
                    ))
                }
            </Fragment>
        )
    }

    {
        grouped.additional.length > 0 && (
            <Fragment slot="additional">
                {
                    grouped.additional.map((ref) => (
                        <ReferenceEntry
                            reference={ref} preparedSlots={preparedSlots[ref.id] || {}}
                            {...(fallbackTitles[ref.id]
                                ? { fallbackTitle: fallbackTitles[ref.id] }
                                : {})}
                        />
                    ))
                }
            </Fragment>
        )
    }
</References>
