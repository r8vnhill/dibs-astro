---
import {
    type BibliographyJsonLd,
    type NormalizedReference,
    parseBibliography,
    resolveReferenceGroups,
} from "~/lib/bibliography";
import AuthorList from "./AuthorList.astro";
import Book from "./Book.astro";
import { resolveOptionalSlot } from "./reference-content";
import References from "./References.astro";
import ScholarlyArticle from "./ScholarlyArticle.astro";
import Thesis from "./Thesis.astro";
import WebPage from "./WebPage.astro";

type Props = {
    source: BibliographyJsonLd | Record<string, unknown>;
    recommended: string[];
    additional?: string[];
    heading?: string;
    recommendedHeading?: string;
    additionalHeading?: string;
    strict?: boolean;
};

const {
    source,
    recommended,
    additional = [],
    heading,
    recommendedHeading,
    additionalHeading,
    strict = true,
}: Props = Astro.props;

const parsed = parseBibliography(source, {
    strict,
    sourceLabel: "ReferencesFromJsonLd",
});

const grouped = resolveReferenceGroups(parsed, recommended, additional, {
    strict,
    sourceLabel: "ReferencesFromJsonLd",
});

const descriptionSlotName = (ref: NormalizedReference): string => `description-${ref.id}`;
const titleSlotName = (ref: NormalizedReference): string => `title-${ref.id}`;
const publicationSlotName = (ref: ArticleReference): string => `publication-${ref.id}`;
const institutionSlotName = (ref: ThesisReference): string => `institution-${ref.id}`;
const referencesProps = {
    ...(heading ? { heading } : {}),
    ...(recommendedHeading ? { recommendedHeading } : {}),
    ...(additionalHeading ? { additionalHeading } : {}),
};

const referencedIds = Array.from(new Set([...recommended, ...additional]));
const slotHtml = new Map<string, string>();
const fallbackTitleById = new Map<string, string>();

const isObject = (value: unknown): value is Record<string, unknown> =>
    typeof value === "object" && value !== null;

const asNonEmptyString = (value: unknown): string | undefined => {
    if (typeof value !== "string") return undefined;
    const trimmed = value.trim();
    return trimmed.length > 0 ? trimmed : undefined;
};

if (isObject(source) && Array.isArray(source.itemListElement)) {
    for (const rawItem of source.itemListElement) {
        if (!isObject(rawItem)) continue;
        const id = asNonEmptyString(rawItem.identifier);
        const title = asNonEmptyString(rawItem.name) ?? asNonEmptyString(rawItem.headline);
        if (id && title) fallbackTitleById.set(id, title);
    }
}

type BookReference = Extract<NormalizedReference, { type: "Book" }>;
type WebReference = Extract<NormalizedReference, { type: "WebPage" }>;
type ArticleReference = Extract<NormalizedReference, { type: "ScholarlyArticle" }>;
type ThesisReference = Extract<NormalizedReference, { type: "Thesis" }>;

const resolvedBookChapter = (ref: BookReference): string | undefined =>
    ref.chapter || ref.title || fallbackTitleById.get(ref.id);

const resolvedWebTitle = (ref: WebReference): string | undefined =>
    ref.title || fallbackTitleById.get(ref.id);

const resolvedArticleTitle = (ref: ArticleReference): string | undefined =>
    ref.title || fallbackTitleById.get(ref.id);

const resolvedThesisTitle = (ref: ThesisReference): string | undefined =>
    ref.title || fallbackTitleById.get(ref.id);

const bookChapterProp = (ref: BookReference): { chapter: string } | Record<never, never> => {
    const chapter = resolvedBookChapter(ref);
    return chapter ? { chapter } : {};
};

const webTitleProp = (ref: WebReference): { title: string } | Record<never, never> => {
    const title = resolvedWebTitle(ref);
    return title ? { title } : {};
};

const articleTitleProp = (ref: ArticleReference): { title: string } | Record<never, never> => {
    const title = resolvedArticleTitle(ref);
    return title ? { title } : {};
};

const thesisTitleProp = (ref: ThesisReference): { title: string } | Record<never, never> => {
    const title = resolvedThesisTitle(ref);
    return title ? { title } : {};
};

for (const id of referencedIds) {
    const titleName = `title-${id}`;
    const titleSlot = await resolveOptionalSlot(Astro.slots, titleName);
    if (titleSlot.kind === "meaningful") {
        slotHtml.set(titleName, titleSlot.html);
    }

    const descriptionName = `description-${id}`;
    const descriptionSlot = await resolveOptionalSlot(Astro.slots, descriptionName);
    if (descriptionSlot.kind === "meaningful") {
        slotHtml.set(descriptionName, descriptionSlot.html);
    }

    const publicationName = `publication-${id}`;
    const publicationSlot = await resolveOptionalSlot(Astro.slots, publicationName);
    if (publicationSlot.kind === "meaningful") {
        slotHtml.set(publicationName, publicationSlot.html);
    }

    const institutionName = `institution-${id}`;
    const institutionSlot = await resolveOptionalSlot(Astro.slots, institutionName);
    if (institutionSlot.kind === "meaningful") {
        slotHtml.set(institutionName, institutionSlot.html);
    }
}
---

<References {...referencesProps}>
    <Fragment slot="recommended">
        {
            grouped.recommended.map((ref) =>
                ref.type === "Book"
                    ? (
                <Book
                    {...bookChapterProp(ref)} bookTitle={ref.bookTitle}
                    {...(ref.pages ? { pages: ref.pages } : {})}
                >
                    {
                        slotHtml.has(titleSlotName(ref)) ? (
                            <Fragment slot="chapter">
                                <span set:html={slotHtml.get(titleSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }

                    {
                        ref.authors.length > 0 ? (
                            <AuthorList slot="authors" authors={ref.authors} />
                        ) : null
                    }

                    {
                        slotHtml.has(descriptionSlotName(ref)) ? (
                            <Fragment slot="description">
                                <div set:html={slotHtml.get(descriptionSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }
                </Book>
            )
            : ref.type === "WebPage"
            ? (
                <WebPage
                    {...webTitleProp(ref)} url={ref.url}
                    {...(ref.location ? { location: ref.location } : {})}
                >
                    {
                        slotHtml.has(titleSlotName(ref)) ? (
                            <Fragment slot="title">
                                <span set:html={slotHtml.get(titleSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }

                    {
                        ref.authors.length > 0 ? (
                            <AuthorList slot="author" authors={ref.authors} />
                        ) : null
                    }

                    {
                        slotHtml.has(descriptionSlotName(ref)) ? (
                            <Fragment slot="description">
                                <div set:html={slotHtml.get(descriptionSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }
                </WebPage>
            )
            : ref.type === "ScholarlyArticle"
            ? (
                <ScholarlyArticle
                    {...articleTitleProp(ref)} url={ref.url}
                    {...(ref.publication ? { publication: ref.publication } : {})}
                    {...(ref.pages ? { pages: ref.pages } : {})}
                >
                    {
                        slotHtml.has(titleSlotName(ref)) ? (
                            <Fragment slot="title">
                                <span set:html={slotHtml.get(titleSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }

                    {
                        slotHtml.has(publicationSlotName(ref)) ? (
                            <Fragment slot="publication">
                                <span set:html={slotHtml.get(publicationSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }

                    {
                        ref.authors.length > 0 ? (
                            <AuthorList slot="author" authors={ref.authors} />
                        ) : null
                    }

                    {
                        slotHtml.has(descriptionSlotName(ref)) ? (
                            <Fragment slot="description">
                                <div set:html={slotHtml.get(descriptionSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }
                </ScholarlyArticle>
            )
            : (
                <Thesis
                    {...thesisTitleProp(ref)} url={ref.url}
                    {...(ref.institution ? { institution: ref.institution } : {})}
                >
                    {
                        slotHtml.has(titleSlotName(ref)) ? (
                            <Fragment slot="title">
                                <span set:html={slotHtml.get(titleSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }

                    {
                        slotHtml.has(institutionSlotName(ref)) ? (
                            <Fragment slot="institution">
                                <span set:html={slotHtml.get(institutionSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }

                    {
                        ref.authors.length > 0 ? (
                            <AuthorList slot="author" authors={ref.authors} />
                        ) : null
                    }

                    {
                        slotHtml.has(descriptionSlotName(ref)) ? (
                            <Fragment slot="description">
                                <div set:html={slotHtml.get(descriptionSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }
                </Thesis>
            )
            )
        }
    </Fragment>

    <Fragment slot="additional">
        {
            grouped.additional.map((ref) =>
                ref.type === "Book"
                    ? (
                <Book
                    {...bookChapterProp(ref)} bookTitle={ref.bookTitle}
                    {...(ref.pages ? { pages: ref.pages } : {})}
                >
                    {
                        slotHtml.has(titleSlotName(ref)) ? (
                            <Fragment slot="chapter">
                                <span set:html={slotHtml.get(titleSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }

                    {
                        ref.authors.length > 0 ? (
                            <AuthorList slot="authors" authors={ref.authors} />
                        ) : null
                    }

                    {
                        slotHtml.has(descriptionSlotName(ref)) ? (
                            <Fragment slot="description">
                                <div set:html={slotHtml.get(descriptionSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }
                </Book>
            )
            : ref.type === "WebPage"
            ? (
                <WebPage
                    {...webTitleProp(ref)} url={ref.url}
                    {...(ref.location ? { location: ref.location } : {})}
                >
                    {
                        slotHtml.has(titleSlotName(ref)) ? (
                            <Fragment slot="title">
                                <span set:html={slotHtml.get(titleSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }

                    {
                        ref.authors.length > 0 ? (
                            <AuthorList slot="author" authors={ref.authors} />
                        ) : null
                    }

                    {
                        slotHtml.has(descriptionSlotName(ref)) ? (
                            <Fragment slot="description">
                                <div set:html={slotHtml.get(descriptionSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }
                </WebPage>
            )
            : ref.type === "ScholarlyArticle"
            ? (
                <ScholarlyArticle
                    {...articleTitleProp(ref)} url={ref.url}
                    {...(ref.publication ? { publication: ref.publication } : {})}
                    {...(ref.pages ? { pages: ref.pages } : {})}
                >
                    {
                        slotHtml.has(titleSlotName(ref)) ? (
                            <Fragment slot="title">
                                <span set:html={slotHtml.get(titleSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }

                    {
                        slotHtml.has(publicationSlotName(ref)) ? (
                            <Fragment slot="publication">
                                <span set:html={slotHtml.get(publicationSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }

                    {
                        ref.authors.length > 0 ? (
                            <AuthorList slot="author" authors={ref.authors} />
                        ) : null
                    }

                    {
                        slotHtml.has(descriptionSlotName(ref)) ? (
                            <Fragment slot="description">
                                <div set:html={slotHtml.get(descriptionSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }
                </ScholarlyArticle>
            )
            : (
                <Thesis
                    {...thesisTitleProp(ref)} url={ref.url}
                    {...(ref.institution ? { institution: ref.institution } : {})}
                >
                    {
                        slotHtml.has(titleSlotName(ref)) ? (
                            <Fragment slot="title">
                                <span set:html={slotHtml.get(titleSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }

                    {
                        slotHtml.has(institutionSlotName(ref)) ? (
                            <Fragment slot="institution">
                                <span set:html={slotHtml.get(institutionSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }

                    {
                        ref.authors.length > 0 ? (
                            <AuthorList slot="author" authors={ref.authors} />
                        ) : null
                    }

                    {
                        slotHtml.has(descriptionSlotName(ref)) ? (
                            <Fragment slot="description">
                                <div set:html={slotHtml.get(descriptionSlotName(ref))} />
                            </Fragment>
                        ) : null
                    }
                </Thesis>
            )
            )
        }
    </Fragment>
</References>
