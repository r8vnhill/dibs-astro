---
/**
 * @file Renders a thesis reference in the shared bibliography list.
 *
 * `Thesis` is a thin rendering component. It delegates slot/prop precedence, runtime validation, and link resolution 
 * to `resolveThesisReference(...)`, then renders the resulting view model.
 *
 * Content resolution follows the reference-family contract:
 *
 * - meaningful named slots take precedence over prop fallbacks;
 * - prop fallbacks are used only when the corresponding slot is absent or empty;
 * - slot-backed content is rendered as caller-authored markup;
 * - prop-backed institution text may be linked through `institutionUrl`;
 * - slot-backed institution content is never wrapped automatically.
 *
 * The resolver validates the public reference contract before rendering:
 *
 * - the thesis title must resolve to meaningful content;
 * - `url` must resolve to a non-empty external link target;
 * - `institutionUrl` requires a meaningful institution label.
 */
import * as icons from "~/assets/img/icons";
import { Enquote } from "~/components/semantics";
import { ListItem } from "~/components/ui/list";
import { resolveOptionalSlots, SPANISH_REFERENCE_META_LABELS } from "./reference-content";
import { EXTERNAL_REFERENCE_LINK_ATTRS } from "./reference-links";
import { resolveThesisReference, THESIS_REFERENCE_SLOTS } from "./thesis-reference";

/**
 * Props for rendering a thesis reference.
 *
 * Named slots can override the textual fallbacks for `title`, `institution`, `author`, and `description`. Prefer 
 * slots when the rendered content needs custom markup; prefer props for plain text metadata.
 */
type Props = {
    /**
     * Plain-text fallback thesis title.
     *
     * Used only when the `title` slot is absent or does not contain meaningful content. The resolved title is always 
     * rendered as the primary thesis link.
     */
    title?: string;

    /**
     * Canonical external URL for the thesis.
     *
     * The value is validated before rendering and used as the `href` of the primary title link.
     */
    url: string;

    /**
     * Plain-text fallback institution name.
     *
     * Used only when the `institution` slot is absent or empty. When `institutionUrl` is also provided, this 
     * prop-backed text is rendered as a link.
     */
    institution?: string;

    /**
     * Optional external URL for prop-backed institution text.
     *
     * This value is ignored when the institution is provided through a slot, because slot content is treated as 
     * already-authored markup.
     */
    institutionUrl?: string;

    /**
     * Plain-text fallback author label.
     *
     * Used only when the `author` slot is absent or does not contain meaningful content.
     */
    author?: string;
};

const slots = await resolveOptionalSlots(Astro.slots, THESIS_REFERENCE_SLOTS);
const reference = resolveThesisReference(Astro.props, slots);
---

<ListItem icon={icons.Student}>
    <Enquote type="english-double">
        <a href={reference.url} {...EXTERNAL_REFERENCE_LINK_ATTRS}>
            {
                /*
                 * Slot-backed fields contain rendered Astro slot HTML. They are treated as trusted caller-authored 
                 * markup by the reference content resolver.
                 */
                reference.title.kind === "slot"
                    ? <span set:html={reference.title.html} />
                : reference.title.text
            }
        </a>
    </Enquote>

    {
        reference.institution.kind !== "missing" ? (
            <span>
                {" "}<span class="text-muted-foreground">{SPANISH_REFERENCE_META_LABELS.in}</span> {
                    reference.institution.kind === "slot"
                        ? <span set:html={reference.institution.html} />
                    : reference.institution.kind === "link"
                    ? (
                        <a href={reference.institution.href} {...EXTERNAL_REFERENCE_LINK_ATTRS}>
                            {reference.institution.text}
                        </a>
                    )
                    : reference.institution.text
                }
            </span>
        ) : null
    }

    {
        reference.author.kind !== "missing" ? (
            <span>
                {" "}<span class="text-muted-foreground">{SPANISH_REFERENCE_META_LABELS.by}</span> {
                    reference.author.kind === "slot"
                        ? <span set:html={reference.author.html} />
                    : reference.author.text
                }
            </span>
        ) : null
    }

    {
        reference.description.kind === "meaningful" ? (
            <div class="text-muted-foreground">
                <span set:html={reference.description.html} />
            </div>
        ) : null
    }
</ListItem>
