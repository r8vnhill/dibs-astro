---
import * as icons from "~/assets/img/icons";
import { Enquote } from "~/components/semantics";
import { ListItem } from "~/components/ui/list";
import { resolveOptionalSlot, SPANISH_REFERENCE_META_LABELS } from "./reference-content";

type Props = {
    title?: string;
    url: string;
    institution?: string;
    author?: string;
};

const { title, url, institution, author }: Props = Astro.props;
const titleSlot = await resolveOptionalSlot(Astro.slots, "title");
const institutionSlot = await resolveOptionalSlot(Astro.slots, "institution");
const authorSlot = await resolveOptionalSlot(Astro.slots, "author");
const descriptionSlot = await resolveOptionalSlot(Astro.slots, "description");
---

<ListItem icon={icons.Student}>
    <Enquote type="english-double">
        <a
            href={url} target="_blank"
            rel="noopener noreferrer" class="hover:underline underline-offset-2"
        >
            {titleSlot.hasContent ? <slot name="title" /> : title}
        </a>
    </Enquote>

    {
        institutionSlot.hasContent || institution ? (
            <span>
                {" "}<span class="text-muted-foreground">{SPANISH_REFERENCE_META_LABELS.in}</span>{
                    " "
                }
                {institutionSlot.hasContent ? <slot name="institution" /> : institution}
            </span>
        ) : null
    }

    {
        authorSlot.hasContent || author ? (
            <span>
                {" "}<span class="text-muted-foreground">{SPANISH_REFERENCE_META_LABELS.by}</span>{
                    " "
                }
                {authorSlot.hasContent ? <slot name="author" /> : author}
            </span>
        ) : null
    }

    {
        descriptionSlot.hasContent ? (
            <div class="text-muted-foreground block">
                <slot name="description" />
            </div>
        ) : null
    }
</ListItem>
