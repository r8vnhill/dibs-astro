---
/**
 * Renders a video reference in the shared bibliography list.
 *
 * The component follows the same fallback and slot rules as the rest of the reference family,
 * while prioritizing author and platform metadata for audiovisual material.
 */
import { resolveInlineField, resolveLinkedInlineField } from "$domain/reference-content";
import * as icons from "~/assets/img/icons";
import { Enquote } from "~/components/semantics";
import { ListItem } from "~/components/ui/list";
import {
    resolveOptionalSlots,
    resolveRequiredTitleField,
    SPANISH_REFERENCE_META_LABELS,
} from "./reference-content";
import { ReferenceContractError } from "./ReferenceContractError";

type Props = {
    title?: string;
    url: string;
    platform?: string;
    platformUrl?: string;
    author?: string;
    date?: string;
};

const { title, url, platform, platformUrl, author, date }: Props = Astro.props;
const {
    title: titleSlot,
    platform: platformSlot,
    author: authorSlot,
    description: descriptionSlot,
} = await resolveOptionalSlots(Astro.slots, ["title", "platform", "author", "description"]);

const externalLinkAttrs = {
    target: "_blank",
    rel: "noopener noreferrer",
    class: "hover:underline underline-offset-2",
} as const;

const resolvedTitle = resolveRequiredTitleField(titleSlot, title);
const resolvedAuthor = resolveInlineField(authorSlot, author);
const resolvedPlatform = resolveLinkedInlineField(platformSlot, platform, platformUrl);

if (import.meta.env.DEV && platformUrl && !platform) {
    throw new ReferenceContractError("Video `platformUrl` requires `platform`.");
}
---

<ListItem icon={icons.PlayCircle}>
    <Enquote type="english-double">
        <a href={url} {...externalLinkAttrs}>
            {
                resolvedTitle.kind === "slot"
                    ? <span set:html={resolvedTitle.html} />
                : resolvedTitle.text
            }
        </a>
    </Enquote>

    {
        resolvedAuthor.kind !== "missing" ? (
            <span>
                {" "}<span class="text-muted-foreground">{SPANISH_REFERENCE_META_LABELS.by}</span> {
                    resolvedAuthor.kind === "slot"
                        ? <span set:html={resolvedAuthor.html} />
                    : resolvedAuthor.text
                }
            </span>
        ) : null
    }

    {
        resolvedPlatform.kind !== "missing" ? (
            <span>
                {" "}<span class="text-muted-foreground">{SPANISH_REFERENCE_META_LABELS.in}</span> {
                    resolvedPlatform.kind === "slot"
                        ? <span set:html={resolvedPlatform.html} />
                    : resolvedPlatform.kind === "link"
                    ? (
                        <a href={resolvedPlatform.href} {...externalLinkAttrs}>
                            {resolvedPlatform.text}
                        </a>
                    )
                    : resolvedPlatform.text
                }
            </span>
        ) : null
    }

    {
        date ? (
            <span class="text-muted-foreground">
                {" "}({date})
            </span>
        ) : null
    }

    {
        descriptionSlot.kind === "meaningful" ? (
            <div class="text-muted-foreground">
                <span set:html={descriptionSlot.html} />
            </div>
        ) : null
    }
</ListItem>
