---
/**
 * References assembler for bibliography catalog sources.
 *
 * This component loads references from a precompiled bibliography catalog, filters by lesson ID
 * and optional tags, resolves all bibliography-related slots, and renders references through
 * a shared entry-rendering pipeline.
 *
 * Unlike the JSON-LD assembler, the catalog already provides normalized reference data,
 * so no raw-source title extraction is needed.
 */

import {
    type BibliographyCatalog,
    getReferencesForLesson,
    loadBibliographyCatalog,
    type LoadBibliographyCatalogOptions,
    type ReferenceTag,
} from "~/lib/bibliography";
import { getDefaultBibliographyCatalog } from "$presentation/adapters/bibliography-catalog";
import { prepareSlotsForReferences } from "./reference-content";
import ReferenceEntry from "./ReferenceEntry.astro";
import References from "./References.astro";

type Props = {
    source?: BibliographyCatalog | Record<string, unknown>;
    lessonId?: string;
    includeTags?: ReferenceTag[];
    excludeTags?: ReferenceTag[];
    includePendingRevision?: boolean;
    heading?: string;
    recommendedHeading?: string;
    additionalHeading?: string;
    strict?: boolean;
};

const {
    source = getDefaultBibliographyCatalog(),
    lessonId,
    includeTags,
    excludeTags,
    includePendingRevision = false,
    heading,
    recommendedHeading,
    additionalHeading,
    strict = true,
}: Props = Astro.props;

const resolvedLessonId = lessonId ?? Astro.url.pathname;

// Load or validate the bibliography catalog
const catalog = "referencesById" in source
    ? source as BibliographyCatalog
    : loadBibliographyCatalog(
        source,
        {
            strict,
            sourceLabel: "ReferencesFromCatalog",
        } satisfies LoadBibliographyCatalogOptions,
    );

// Retrieve and group references for the current lesson
const grouped = getReferencesForLesson(catalog, resolvedLessonId, {
    ...(includeTags ? { includeTags } : {}),
    ...(excludeTags ? { excludeTags } : {}),
    includePendingRevision,
});

// Collect all referenced IDs for batch slot preparation
const referencedIds = Array.from(
    new Set([
        ...grouped.recommended.map((entry) => entry.reference.id),
        ...grouped.additional.map((entry) => entry.reference.id),
    ]),
);

// Prepare all meaningful slot overrides in one async pass
const preparedSlots = await prepareSlotsForReferences(Astro.slots, referencedIds);

const referencesProps = {
    ...(heading ? { heading } : {}),
    ...(recommendedHeading ? { recommendedHeading } : {}),
    ...(additionalHeading ? { additionalHeading } : {}),
};
---

<References {...referencesProps}>
    {
        grouped.recommended.length > 0 && (
            <Fragment slot="recommended">
                {
                    grouped.recommended.map((entry) => (
                        <ReferenceEntry
                            reference={entry.reference}
                            preparedSlots={preparedSlots[entry.reference.id] || {}}
                        />
                    ))
                }
            </Fragment>
        )
    }

    {
        grouped.additional.length > 0 && (
            <Fragment slot="additional">
                {
                    grouped.additional.map((entry) => (
                        <ReferenceEntry
                            reference={entry.reference}
                            preparedSlots={preparedSlots[entry.reference.id] || {}}
                        />
                    ))
                }
            </Fragment>
        )
    }
</References>
