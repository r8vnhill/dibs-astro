---
/**
 * WebPage.astro
 * -------------
 * Renders a reference to an external webpage, typically used inside a list of learning resources.
 * It accepts optional metadata such as location (e.g. "Kotlin Docs"), author, and a description.
 */

import * as icons from "~/assets/img/icons";
import { ListItem } from "~/components/ui/list";
import { resolveOptionalSlot, SPANISH_REFERENCE_META_LABELS } from "./reference-content";

// Define props and destructure them from Astro.props
type Props = {
    /**
     * The external URL to link to.
     */
    url: string;
    /**
     * The title of the page (if not passed via slot).
     */
    title?: string;
    /**
     * The source or site where this page is published (if not passed via slot).
     */
    location?: string;
    /**
     * Author or contributor name (if not passed via slot).
     */
    author?: string;
};

const { url, title, location, author }: Props = Astro.props;
const titleSlot = await resolveOptionalSlot(Astro.slots, "title");
const locationSlot = await resolveOptionalSlot(Astro.slots, "location");
const authorSlot = await resolveOptionalSlot(Astro.slots, "author");
const descriptionSlot = await resolveOptionalSlot(Astro.slots, "description");
---

<ListItem icon={icons.Globe}>
    “<a
        href={url} target="_blank"
        rel="noopener noreferrer" class="hover:underline underline-offset-2"
    >
        {titleSlot.hasContent ? <slot name="title" /> : title}
    </a>”

    {
        locationSlot.hasContent || location ? (
            <span>
                {" "}<span class="text-muted-foreground">{SPANISH_REFERENCE_META_LABELS.in}</span>{
                    " "
                }
                {locationSlot.hasContent ? <slot name="location" /> : location}
            </span>
        ) : null
    }

    {
        authorSlot.hasContent || author ? (
            <span>
                {" "}<span class="text-muted-foreground">{SPANISH_REFERENCE_META_LABELS.by}</span>{
                    " "
                }
                {authorSlot.hasContent ? <slot name="author" /> : author}
            </span>
        ) : null
    }

    {
        descriptionSlot.hasContent ? (
            <div class="text-muted-foreground block">
                <slot name="description" />
            </div>
        ) : null
    }
</ListItem>
