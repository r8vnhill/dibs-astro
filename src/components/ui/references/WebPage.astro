---
/**
 * WebPage.astro
 * -------------
 * Renders a reference to an external webpage, typically used inside a list of learning resources.
 * It accepts optional metadata such as location (e.g. "Kotlin Docs"), author, and a description.
 */

import * as icons from "~/assets/img/icons";
import { Enquote } from "~/components/semantics";
import { ListItem } from "~/components/ui/list";
import {
    resolveOptionalSlots,
    resolveRequiredTitleField,
    resolveInlineField,
    resolveLinkedInlineField,
    SPANISH_REFERENCE_META_LABELS,
} from "./reference-content";
import { ReferenceContractError } from "./ReferenceContractError";

// Define props and destructure them from Astro.props
type Props = {
    /**
     * The external URL to link to.
     */
    url: string;
    /**
     * The title of the page (if not passed via slot).
     */
    title?: string;
    /**
     * The source or site where this page is published (if not passed via slot).
     */
    location?: string;
    /**
     * Optional URL for the source or site metadata.
     */
    locationUrl?: string;
    /**
     * Author or contributor name (if not passed via slot).
     */
    author?: string;
};

const { url, title, location, locationUrl, author }: Props = Astro.props;
const {
    title: titleSlot,
    location: locationSlot,
    author: authorSlot,
    description: descriptionSlot,
} = await resolveOptionalSlots(Astro.slots, ["title", "location", "author", "description"]);

const externalLinkAttrs = {
    target: "_blank",
    rel: "noopener noreferrer",
    class: "hover:underline underline-offset-2",
} as const;

const resolvedTitle = resolveRequiredTitleField(titleSlot, title);
const resolvedLocation = resolveLinkedInlineField(locationSlot, location, locationUrl);
const resolvedAuthor = resolveInlineField(authorSlot, author);

if (import.meta.env.DEV && locationUrl && !location) {
    throw new ReferenceContractError("WebPage `locationUrl` requires `location`.");
}
---

<ListItem icon={icons.Globe}>
    <Enquote type="english-double">
        <a href={url} {...externalLinkAttrs}>
            {
                resolvedTitle.kind === "slot"
                    ? <span set:html={resolvedTitle.html} />
                : resolvedTitle.text
            }
        </a>
    </Enquote>

    {
        resolvedLocation.kind !== "missing" ? (
            <span>
                {" "}<span class="text-muted-foreground">{SPANISH_REFERENCE_META_LABELS.in}</span>{
                    " "
                }
                {
                    resolvedLocation.kind === "slot"
                        ? <span set:html={resolvedLocation.html} />
                    : resolvedLocation.kind === "link"
                    ? (
                        <a href={resolvedLocation.href} {...externalLinkAttrs}>
                            {resolvedLocation.text}
                        </a>
                    )
                    : resolvedLocation.text
                }
            </span>
        ) : null
    }

    {
        resolvedAuthor.kind !== "missing" ? (
            <span>
                {" "}<span class="text-muted-foreground">{SPANISH_REFERENCE_META_LABELS.by}</span>{
                    " "
                }
                {
                    resolvedAuthor.kind === "slot"
                        ? <span set:html={resolvedAuthor.html} />
                    : resolvedAuthor.text
                }
            </span>
        ) : null
    }

    {
        descriptionSlot.kind === "meaningful" ? (
            <div class="text-muted-foreground">
                <span set:html={descriptionSlot.html} />
            </div>
        ) : null
    }
</ListItem>
