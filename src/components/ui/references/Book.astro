---
import * as icons from "~/assets/img/icons";
import { Enquote } from "~/components/semantics";
import { ListItem } from "~/components/ui/list";
import { formatPageReference, type PageReference } from "~/lib/bibliography";
import { resolveOptionalSlots, SPANISH_REFERENCE_META_LABELS } from "./reference-content";

type Props = {
    chapter?: string;
    pages?: PageReference;
    bookTitle?: string;
    authors?: string[];
    quoteType?: "latin-double" | "latin-single" | "english-double" | "english-single";
    italicTitle?: boolean;
    locale?: "es" | "en";
};

const {
    chapter,
    pages,
    bookTitle,
    authors,
    quoteType = "english-double",
    italicTitle = true,
    locale = "es",
} = Astro.props as Props;

const authorsText = (arr?: string[], loc: "es" | "en" = "es") => {
    if (!arr || arr.length === 0) return null;
    const lf = new Intl.ListFormat(loc, { style: "long", type: "conjunction" });
    return lf.format(arr);
};

const pagesLabel = formatPageReference(pages);
const authorsInline = authorsText(authors, locale);
const byWord = locale === "en" ? "by" : SPANISH_REFERENCE_META_LABELS.by;
const inWord = locale === "en" ? "in" : SPANISH_REFERENCE_META_LABELS.in;
const {
    chapter: chapterSlot,
    bookTitle: bookTitleSlot,
    authors: authorsSlot,
    description: descriptionSlot,
} = await resolveOptionalSlots(Astro.slots, ["chapter", "bookTitle", "authors", "description"]);
---

<ListItem icon={icons.Book} class="space-y-1">
    <div class="flex flex-wrap items-baseline gap-x-1.5">
        <Enquote type={quoteType}>
            {chapterSlot.kind === "meaningful" ? <slot name="chapter" /> : chapter}
        </Enquote>

        {
            pagesLabel && (
                <span class="text-muted-foreground" aria-label={pagesLabel}>
                    ({pagesLabel})
                </span>
            )
        }

        <span class="text-muted-foreground">{inWord}</span>

        <cite class:list={["not-italic", italicTitle && "italic"]}>
            {bookTitleSlot.kind === "meaningful" ? <slot name="bookTitle" /> : bookTitle}
        </cite>

        <span class="text-muted-foreground">{byWord}</span>

        {
            authorsInline
                ? <span>{authorsInline}</span>
            : (authorsSlot.kind === "meaningful" ? <slot name="authors" /> : null)
        }
    </div>

    {
        descriptionSlot.kind === "meaningful" && (
            <div class="text-muted-foreground">
                <slot name="description" />
            </div>
        )
    }
</ListItem>
