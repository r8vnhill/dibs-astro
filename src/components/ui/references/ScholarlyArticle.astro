---
/**
 * Renders a scholarly article reference in the shared bibliography list.
 *
 * The component accepts plain string props for common metadata and named slots when richer markup
 * is needed. Slot content only wins when the rendered output is meaningful; otherwise the matching
 * prop is used as a fallback.
 *
 * Supported slots:
 * - `title`
 * - `publication`
 * - `author`
 * - `description`
 *
 * Rendering rules:
 * - `url` is required because the title is always linked externally.
 * - `pages` is formatted through the shared bibliography utility.
 * - `description` is rendered only when the slot contains meaningful content.
 */
import * as icons from "~/assets/img/icons";
import { Enquote } from "~/components/semantics";
import { ListItem } from "~/components/ui/list";
import {
    formatPageReference,
    isPageReference,
    type PageReference,
    type PageReferenceInput,
    parsePageReferenceInput,
} from "~/lib/bibliography";
import {
    resolveInlineField,
    resolveLinkedInlineField,
    resolveOptionalSlots,
    resolveRequiredTitleField,
    SPANISH_REFERENCE_META_LABELS,
} from "./reference-content";
import { ReferenceContractError } from "./ReferenceContractError";

type Props = {
    /** Fallback article title when the `title` slot is absent or empty. */
    title?: string;

    /** Canonical external URL for the article. */
    url: string;

    /** Fallback container publication name. */
    publication?: string;

    /** Optional URL for the publication metadata. */
    publicationUrl?: string;

    /** Optional page reference formatted by the shared bibliography layer. */
    pages?: PageReference | PageReferenceInput;

    /** Fallback author text when the `author` slot is absent or empty. */
    author?: string;
};

const { title, url, publication, publicationUrl, pages, author }: Props = Astro.props;

// Resolve optional slots once so the template stays declarative.
const {
    title: titleSlot,
    publication: publicationSlot,
    author: authorSlot,
    description: descriptionSlot,
} = await resolveOptionalSlots(Astro.slots, ["title", "publication", "author", "description"]);

// Pre-format the page reference so the template only handles presentation.
const normalizedPages = isPageReference(pages) ? pages : parsePageReferenceInput(pages);
const pagesLabel = formatPageReference(normalizedPages);

const externalLinkAttrs = {
    target: "_blank",
    rel: "noopener noreferrer",
    class: "hover:underline underline-offset-2",
} as const;

const resolvedTitle = resolveRequiredTitleField(titleSlot, title);
const resolvedPublication = resolveLinkedInlineField(
    publicationSlot,
    publication,
    publicationUrl,
);
const resolvedAuthor = resolveInlineField(authorSlot, author);

if (import.meta.env.DEV && publicationUrl && !publication) {
    throw new ReferenceContractError("ScholarlyArticle `publicationUrl` requires `publication`.");
}
---

<ListItem icon={icons.FileText}>
    <Enquote type="english-double">
        <a href={url} {...externalLinkAttrs}>
            {
                resolvedTitle.kind === "slot"
                    ? <span set:html={resolvedTitle.html} />
                : resolvedTitle.text
            }
        </a>
    </Enquote>

    {
        pagesLabel ? (
            <span class="text-muted-foreground">
                {" "}({pagesLabel})
            </span>
        ) : null
    }

    {
        resolvedPublication.kind !== "missing" ? (
            <span>
                {" "}<span class="text-muted-foreground">{SPANISH_REFERENCE_META_LABELS.in}</span>{
                    " "
                }
                <cite class="not-italic">
                    {
                        resolvedPublication.kind === "slot"
                            ? <span set:html={resolvedPublication.html} />
                        : resolvedPublication.kind === "link"
                        ? (
                            <a href={resolvedPublication.href} {...externalLinkAttrs}>
                                {resolvedPublication.text}
                            </a>
                        )
                        : resolvedPublication.text
                    }
                </cite>
            </span>
        ) : null
    }

    {
        resolvedAuthor.kind !== "missing" ? (
            <span>
                {" "}<span class="text-muted-foreground">{SPANISH_REFERENCE_META_LABELS.by}</span>{
                    " "
                }
                {
                    resolvedAuthor.kind === "slot"
                        ? <span set:html={resolvedAuthor.html} />
                    : resolvedAuthor.text
                }
            </span>
        ) : null
    }

    {
        descriptionSlot.kind === "meaningful" ? (
            <div class="text-muted-foreground">
                <span set:html={descriptionSlot.html} />
            </div>
        ) : null
    }
</ListItem>
