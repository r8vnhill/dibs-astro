---
/**
 * FishBlock.astro
 * ---------------
 * Lightweight wrapper for fish shell snippets.
 * Reuses bash highlighting for now because the course does not yet ship
 * a dedicated fish grammar wrapper.
 */
import * as Icons from "~/assets/img/icons";
import { CodeBlock } from "~/components/ui/code";

const { code, class: className = "" } = Astro.props;
---

<CodeBlock
    lang="bash" icon={Icons.Fish}
    {code} class={className}
>
    <span slot="title">
        <slot name="title" />
    </span>
    <span slot="source">
        <slot name="source" />
    </span>
</CodeBlock>
