# Canonical website and documentation-site nodes reused across the bibliography graph.
#
# Use this file for stable website containers that group related web pages. Keep real publishers
# in `02-organizations.ttl` and link documentation pages to these sites with `schema:isPartOf`.
@prefix schema: <https://schema.org/> .
@prefix dibs: <https://dibs.ravenhill.cl/vocab#> .
@prefix ref: <https://dibs.ravenhill.cl/bibliography/ref/> .
@prefix person: <https://dibs.ravenhill.cl/bibliography/person/> .
@prefix site: <https://dibs.ravenhill.cl/bibliography/site/> .
@prefix org: <https://dibs.ravenhill.cl/bibliography/org/> .
@prefix work: <https://dibs.ravenhill.cl/bibliography/work/> .
@prefix usage: <https://dibs.ravenhill.cl/bibliography/usage/> .

site:kotlin-docs
  a schema:WebSite ;
  schema:name "Kotlin docs" ;
  schema:url "https://kotlinlang.org/docs/" .