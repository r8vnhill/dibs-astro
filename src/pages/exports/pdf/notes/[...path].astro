---
import {
    getLessonPdfExportEntries,
    resolveLessonPdfExportPage,
    type LessonExportManifestEntry,
} from "~/presentation/adapters/lesson-pdf-export";

export const prerender = true;

export function getStaticPaths() {
    return getLessonPdfExportEntries().map((entry: LessonExportManifestEntry) => ({
        params: {
            path: entry.route === "/notes/"
                ? undefined
                : entry.route.slice("/notes/".length, -1),
        },
        props: {
            entry,
        },
    }));
}

const { entry } = Astro.props as {
    readonly entry: LessonExportManifestEntry;
};

const lessonPage = resolveLessonPdfExportPage(entry.route);
Astro.locals.lessonRenderMode = "pdf";
Astro.locals.lessonRoute = entry.route;
const LessonPage = lessonPage.component as any;
---

<LessonPage renderMode="pdf" />
