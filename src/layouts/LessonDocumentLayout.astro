---
/**
 * @file LessonDocumentLayout.astro
 *
 * Reusable document-oriented lesson composition extracted from `NotesLayout.astro`.
 *
 * This layout owns the content that belongs to the lesson document itself:
 *
 * - Lesson title
 * - Optional metadata panel
 * - Optional repository links panel
 * - Abstract slot and fallback
 * - Main lesson body
 *
 * Browser-shell concerns such as sidebars, reading-time widgets, and previous/next navigation are
 * intentionally left to `NotesLayout.astro`.
 *
 * ## Export Mode
 *
 * This layout supports an optional render mode to produce deterministic, hydration-free HTML for PDF export.
 * When `renderMode="pdf"` or `Astro.locals.lessonRenderMode` is set to `"pdf"`:
 *
 * - Child components like Tabs and CodeLayout render static, export-appropriate output.
 * - Interactive scripts and hydration are avoided.
 * - Export markers are added to the document root for PDF selectors.
 */

import LessonMetaPanel from "~/components/notes/LessonMetaPanel.astro";
import LessonRepoPanel from "~/components/notes/LessonRepoPanel.astro";
import { Abstract } from "~/components/ui/callouts";
import ToDo from "~/components/utils/ToDo";
import {
    getLessonExportRootAttributes,
    resolveLessonExportContext,
} from "~/lib/presentation/export-mode";
import type { LessonDocumentLayoutProps } from "~/layouts/LessonDocumentLayout.props";

const { title, metadata, git, renderMode, exportMode } = Astro.props as LessonDocumentLayoutProps;

// Resolve export context from props and request locals.
const exportContext = resolveLessonExportContext({
    renderMode,
    exportMode,
    locals: Astro.locals,
});

const documentAttributes = getLessonExportRootAttributes(exportContext);
---

<article
    id="lesson-content"
    {...documentAttributes}
    class:list={["flex-1", "w-full"]}
>
    <h1 class:list={["text-2xl sm:text-3xl"]}>{title}</h1>

    {
        metadata && (
            <section data-export-role="metadata">
                <LessonMetaPanel {metadata} />
            </section>
        )
    }

    {git && <LessonRepoPanel {git} />}

    <div data-export-role="body">
        <Abstract headingLevel="h2">
            <slot name="abstract">
                <section data-testid="abstract-fallback" data-export-finding="client-only">
                    {
                        exportContext.isPdfExport ? (
                            <aside data-export-hidden="true">
                                Contenido pendiente de completar.
                            </aside>
                        ) : (
                            <ToDo
                                client:only="react"
                                metadata={{
                                    tasks: [
                                        "Agregar abstract",
                                    ],
                                }}
                            />
                        )
                    }
                </section>
            </slot>
        </Abstract>

        <slot />
    </div>
</article>
